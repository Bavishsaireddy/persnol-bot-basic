# .env.example
# Copy this file to .env and fill in your real values.
# The .env file is gitignored and must NEVER be committed.
#
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────


# ── Anthropic (REQUIRED) ──────────────────────────────────────
# Get yours at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Telegram Bot (optional — set telegram.enabled: false in config.yaml to skip) ──
# Create a bot at: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── LangSmith tracing (optional — set to false to disable) ───
# Get yours at: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=bavish-bot


# ── Neo4j code graph (optional — set neo4j.enabled: false in config.yaml to skip) ──
# Local default:  bolt://localhost:7687
# Aura cloud:     neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password


# ── GitHub (optional — for future repo-indexing features) ────
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
